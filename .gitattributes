# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Unity YAML files
*.meta text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.physicsMaterial2D text eol=lf
*.playable text eol=lf
*.overrideController text eol=lf
*.shadergraph text eol=lf
*.shadersubgraph text eol=lf

# Scripts
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.glsl text eol=lf

# Config / data
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.psd binary
*.tga binary
*.tiff binary
*.bmp binary
*.exr binary
*.hdr binary
*.mp3 binary
*.wav binary
*.ogg binary
*.mp4 binary
*.fbx binary
*.obj binary
*.dll binary
*.so binary
*.a binary
*.lib binary
*.dylib binary
*.ttf binary
*.otf binary
*.apk binary
*.aab binary
*.zip binary
